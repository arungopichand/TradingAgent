{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Alpaca": {
    "ApiKey": "YOUR_ALPACA_API_KEY",
    "SecretKey": "YOUR_ALPACA_SECRET_KEY"
  },
  "OpenAI": {
    "ApiKey": "YOUR_OPENAI_API_KEY",
    "Model": "gpt-3.5-turbo"
  },
  "Trading": {
    "AnalysisSymbols": [ "AAPL", "TSLA", "SPY" ],
    "BackgroundSymbols": [ "AAPL", "TSLA", "SPY", "MSFT", "GOOGL", "NVDA" ],
    "DataFetchIntervalMinutes": 60,
    "AlertCheckIntervalMinutes": 5,
    "RunInitialBackgroundFetch": true
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=trading.db"
  }
}
